# Web app
HOST=127.0.0.1
PORT=8080

# OpenAI-compatible LLM proxy
# OpenAI:
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4.1
LLM_API_KEY=

# DashScope / Qwen compatible mode example:
# LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM_MODEL=qwen-plus
# LLM_API_KEY=your_dashscope_api_key

# Milvus Lite knowledge base
# Install these optional RAG dependencies before using real Milvus collections:
# python3 -m pip install -r requirements-rag.txt
RUNTIME_STORE_DIR=./data/runtime
MILVUS_DB_PATH=./data/milvus_knowledge.db
MILVUS_COLLECTION=szlab_knowledge
MILVUS_COLLECTION_HYDROGEN_EXCEL=kb_hydrogen_excel
MILVUS_COLLECTION_SAMR=kb_samr_standards
MILVUS_COLLECTION_MATERIAL_DICTIONARY=kb_material_dictionary
MILVUS_COLLECTION_UPLOADS=kb_uploaded_documents
KNOWLEDGE_MIN_SCORE=0.3
# Optional: set this if your default python3 does not contain pymilvus.
# PYTHON_BIN=/path/to/python3

# Embedding mode for ingestion/search:
# - hash: no external embedding dependency, good for local smoke tests
# - openai: use an OpenAI-compatible /embeddings endpoint
EMBEDDING_MODE=hash
EMBEDDING_DIM=384
# EMBEDDING_BASE_URL=https://api.openai.com/v1
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_API_KEY=
